#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo '🏗️👷 Styling, testing, building, and generating AI embeddings before committing'

npm run format

# Check Prettier standards
npm run check-format ||
(
    echo '🤢🤮🤢🤮 BLEAH - Your styling looks disgusting. 🤢🤮🤢🤮
            Prettier Check Failed. Run npm run format, add changes and try commit again.';
    false;
)

# # Check ESLint Standards
# npm run check-lint ||
# (
#         echo '😤🏀👋😤 Get that out of here! 😤🏀👋😤
#                 ESLint Check Failed. Make the required changes listed above, add changes and try to commit again.'
#         false;
# )

# Check tsconfig standards
npm run check-types ||
(
    echo '🤡😂❌🤡 Failed Type check. 🤡😂❌🤡
            Are you seriously trying to write that? Make the changes required above.'
    false;
)

# Generate AI Embeddings
echo '🧠 Vectorizing project data...'
npx tsx scripts/precomputeEmbeddings.ts ||
(
    echo '🤖💥🚨🤖 AI Malfunction! 🤖💥🚨🤖
            Embedding generation failed. Check your script or JSON data and try again.'
    false;
)

# If everything passes... Now we can commit
echo '✅✅✅✅ You win this time... I am committing this now. ✅✅✅✅'

git add .